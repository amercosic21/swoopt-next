# Copy this file to .env.local only if you want to change a default.
# Everything here is optional - the values below are the built-in defaults, and the
# app runs fine with no .env.local at all.

# --- Binaries ---
# Leave these unset to find the tools on your PATH (recommended). Set an absolute
# path only to pin a specific binary instead of the one on your PATH.

# the yt-dlp executable
YTDLP_BIN=yt-dlp

# the ffmpeg executable (ffprobe is found next to it)
FFMPEG_BIN=ffmpeg

# node, used as yt-dlp's JS runtime for YouTube on Windows
NODE_BIN=node

# --- Behavior ---

# how many downloads run at once; the rest wait in a queue
MAX_CONCURRENT_JOBS=3

# how long finished downloads stay in your history before they're auto-cleared,
# in seconds (86400 = 24 hours)
JOB_TTL=86400
