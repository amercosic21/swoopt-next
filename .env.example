# Copy this file to .env.local and adjust as needed.
# All values are optional; the defaults assume the binaries are on your PATH.

# Path to the yt-dlp binary
YTDLP_BIN=yt-dlp

# Path to the ffmpeg binary (used for merging/remuxing)
FFMPEG_BIN=ffmpeg

# Path to the Node binary (used as yt-dlp's JS runtime for YouTube on Windows)
NODE_BIN=node

# Max simultaneous downloads
MAX_CONCURRENT_JOBS=3

# How long finished job records are kept, in seconds (default: 24h)
JOB_TTL=86400
